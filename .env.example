# Environment Secrets Template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# ─── eBay Developer Credentials ─────────────────────────────────────────────
# Register at: https://developer.ebay.com/
EBAY_APP_ID=
EBAY_CERT_ID=

# ─── PostgreSQL Credentials ──────────────────────────────────────────────────
DATABASE_USER=ebay
DATABASE_PASSWORD=change_me_to_a_strong_password

# ─── API Bearer Token ────────────────────────────────────────────────────────
# Only used when auth.enabled = true in config.toml.
# Generate a strong random token, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=
